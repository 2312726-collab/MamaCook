<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MamaCook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <style name="Theme.MamaCook" parent="Base.Theme.MamaCook" />

    <!-- ĐỊNH NGHĨA LẠI STYLE VÒNG TRÒN CHO ẢNH ĐẠI DIỆN -->
    <style name="Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- STYLE BO GÓC CHO HÌNH ẢNH CÁC BƯỚC NẤU -->
    <style name="RoundedCorner" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <!-- Style cho chữ khi được chọn -->
    <style name="BottomNavTextActive">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- Style cho chữ khi chưa chọn -->
    <style name="BottomNavTextInactive">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">#5D4037</item>
    </style>

    <style name="CategoryButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">#555555</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CategoryButtonActive">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:background">@drawable/bg_register_button</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- STYLE CHO RATINGBAR MÀU VÀNG XỊN -->
    <style name="RatingBarTheme" parent="Theme.AppCompat">
        <item name="colorControlNormal">#D1D1D1</item>
        <item name="colorControlActivated">#FFC107</item>
    </style>
</resources>
