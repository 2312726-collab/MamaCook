<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imgAvatarBinhLuan"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_mama" />

            <TextView
                android:id="@+id/tvTenNguoiBinhLuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgAvatarBinhLuan"
                android:layout_marginStart="12dp"
                android:text="Khách hàng ẩn danh"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvNgayBinhLuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgAvatarBinhLuan"
                android:layout_below="@id/tvTenNguoiBinhLuan"
                android:layout_marginStart="12dp"
                android:text="2 giờ trước"
                android:textColor="#888888"
                android:textSize="12sp" />

            <RatingBar
                android:id="@+id/rbSaoBinhLuan"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:numStars="5"
                android:theme="@style/RatingBarTheme" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvNoiDungBinhLuan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Nội dung đánh giá hiển thị ở đây..."
            android:textColor="#555555"
            android:lineSpacingExtra="3dp"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>